# oratium environment variables — copy to .env and fill in real values.
# Never commit .env. Real secrets stay out of the repo.

# --- OpenAI ---
# Used by the Realtime API for voice agent inference.
OPENAI_API_KEY=sk-...

# --- Twilio ---
# Used by the Twilio Media Streams transport.
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...

# --- Storage ---
# DATABASE_URL: Postgres for tenant config in production.
# Leave unset to fall back to SQLite for local dev / quickstart.
# DATABASE_URL=postgresql://oratium:oratium@localhost:5432/oratium
# ORATIUM_SQLITE_PATH=./oratium.sqlite3

# REDIS_URL: Redis for session state in production.
# Leave unset to fall back to an in-memory store (single-process only).
# REDIS_URL=redis://localhost:6379/0

# --- Secrets encryption ---
# Fernet key used to encrypt tenant secrets at rest in the database.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ORATIUM_FERNET_KEY=

# --- Logging ---
# DEBUG, INFO, WARNING, ERROR. Default INFO.
ORATIUM_LOG_LEVEL=INFO

# --- Observability (optional) ---
# OTLP endpoint for OpenTelemetry trace export. Leave unset to disable export.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_SERVICE_NAME=oratium
